lvs "$circuit1 characterization_top" "$circuit2 characterization_top" /usr/local/lib/python3.12/dist-packages/librelane/scripts/netgen/setup.tcl /foss/designs/sky130_characterization/openlane/characterization_top/runs/RUN_2026-06-19_09-25-21/70-netgen-lvs/reports/lvs.netgen.rpt -blackbox -json
